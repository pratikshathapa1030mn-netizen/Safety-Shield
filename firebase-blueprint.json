{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "workerId": { "type": "string" },
        "workSite": { "type": "string" },
        "role": { "type": "string" },
        "emergencyContact": { "type": "string" },
        "emergencyPhone": { "type": "string" },
        "profileImage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "workerId"]
    },
    "Incident": {
      "title": "Incident",
      "description": "Logged safety incident",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string" },
        "affectedBodyParts": { "type": "array" },
        "evidenceImages": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "description"]
    },
    "TaskLog": {
      "title": "Task Log",
      "description": "Log of a safety task completion",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "taskName": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "checklist": { "type": "array" },
        "riskScore": { "type": "number" }
      },
      "required": ["userId", "taskId", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Collection of logged incidents"
    },
    "/taskLogs/{logId}": {
      "schema": "TaskLog",
      "description": "History of completed tasks and checklists"
    }
  }
}

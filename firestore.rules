rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'workerId', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.workerId is string && data.workerId.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }

    match /incidents/{incidentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /taskLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
